// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  PENDING // compte créé, en attente de validation par un ADMIN
  ADMIN
  KINE
}

// Le cycle de vie porte désormais sur l'étude (et non plus le patient) :
// un patient peut avoir plusieurs études, chacune avec son propre statut.
enum StudyStatus {
  study_pending
  study_completed
  report_sent
  followup_pending
  followup_completed
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW_SENSITIVE
  EXPORT
  ANONYMIZE
}

enum ComponentCategory {
  SELLE
  POTENCE
  CINTRE
  CALE_PIEDS
  MANIVELLES
  PEDALES
  AUTRE
}

enum ExerciseCategory {
  SOUPLESSE
  RENFORCEMENT
  MOBILITE
  PROPRIOCEPTION
  AUTRE
}

enum MeasurementCategory {
  SELLE
  CINTRE
  POTENCE
  POSITION
  CALE_PIEDS
  MANIVELLES
  AUTRE
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  role      Role     @default(PENDING)
  createdBy String?  // id du kiné admin qui a créé ce compte

  patients     Patient[]
  studies      Study[]
  exercises    Exercise[]
  components   BikeComponent[]
  bikeTypes    BikeType[]
  measurements Measurement[]
  auditLogs    AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

model Patient {
  id              String        @id @default(uuid())
  kineId          String
  kine            User          @relation(fields: [kineId], references: [id])

  // Données de base (récupérées via Calendly/n8n)
  email           String        @unique
  firstName       String
  lastName        String
  phone           String?
  calendlyEventId String?

  // Données anonymisées (RGPD) — null si anonymisé
  isAnonymized    Boolean       @default(false)

  intake    PatientIntake?
  studies   Study[]
  followups Followup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kineId])
}

model PatientIntake {
  id        String  @id @default(uuid())
  patientId String  @unique
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Données morphologiques
  heightCm  Float?
  weightKg  Float?

  // Pratique vélo
  bikeType      String?   // route, vtt, gravel, triathlon...
  ridingLevel   String?   // loisir, sportif, compétiteur
  weeklyHours   Float?
  yearsRiding   Int?

  // Douleurs & objectifs
  injuries      String[]  // liste de douleurs déclarées
  goals         String?
  medicalNotes  String?

  // Source des données
  source        String    @default("google_forms") // google_forms | custom_form | manual
  rawData       Json?     // réponses brutes du formulaire

  submittedAt DateTime @default(now())
}

model BikeType {
  id          String   @id @default(uuid())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  name        String   // Route, VTT, Gravel, Triathlon...
  isActive    Boolean  @default(true)

  studies      Study[]
  measurements Measurement[]   @relation("BikeTypeMeasurements")
  components   BikeComponent[] @relation("BikeTypeComponents")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
}

// Une "côte" : mesure relevée pendant une étude. Tronc commun (isCommon) ou
// spécifique à un/plusieurs types de vélo. Gérée par l'admin (CRUD).
model Measurement {
  id          String   @id @default(uuid())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  name        String              // "Hauteur de selle", "Recul de selle"...
  unit        String              // "cm", "mm", "°"
  category    MeasurementCategory @default(AUTRE)
  order       Int                 @default(0) // ordre d'affichage
  isCommon    Boolean             @default(false) // tronc commun (tous les vélos)
  isActive    Boolean             @default(true)

  // Si non commune, liée à un ou plusieurs types de vélo
  bikeTypes   BikeType[] @relation("BikeTypeMeasurements")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
}

model Study {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])
  kineId    String
  kine      User    @relation(fields: [kineId], references: [id])

  // Type de vélo étudié (un patient peut avoir plusieurs études / vélos)
  bikeTypeId String
  bikeType   BikeType @relation(fields: [bikeTypeId], references: [id])

  // Statut du cycle de vie de cette étude
  status    StudyStatus @default(study_pending)

  // Valeurs des côtes saisies pour cette étude : avant/après par côte.
  // Tableau de { measurementId, before, after } — voir StudyMeasureValue.
  measureValues Json @default("[]")

  // Ancien format de mesures à champs fixes (legacy, conservé pour les études
  // antérieures à la refacto des côtes dynamiques). Plus alimenté.
  measures  Json?

  // Liens vers bibliothèque
  componentsUsed       BikeComponent[] @relation("StudyComponents")
  exercisesPrescribed  Exercise[]      @relation("StudyExercises")

  // Rapport
  reportUrl   String?   // URL Vercel Blob du PDF
  reportSentAt DateTime?

  observations String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([kineId])
  @@index([bikeTypeId])
  @@index([status])
}

model Followup {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  // Scores
  painLevel     Int?    // 0-10
  comfortScore  Int?    // 0-10
  satisfactionScore Int? // 0-10

  // Pratique
  ridingFrequency String? // "3×/semaine", etc.
  returningToSport Boolean?

  // Texte libre
  generalFeedback String?

  // Source & données brutes
  source    String  @default("google_forms")
  rawResponses Json? // réponses brutes

  submittedAt DateTime @default(now())

  @@index([patientId])
}

model Exercise {
  id          String          @id @default(uuid())
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])

  name        String
  description String
  category    ExerciseCategory @default(AUTRE)
  frequency   String?          // "2×/jour", "3×/semaine"
  duration    String?          // "30 secondes", "3 séries de 10"
  mediaUrl    String?          // lien vidéo ou image explicative
  isActive    Boolean          @default(true)

  studies     Study[]          @relation("StudyExercises")

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([createdById])
}

model BikeComponent {
  id          String            @id @default(uuid())
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id])

  name        String
  brand       String?
  model       String?
  category    ComponentCategory @default(AUTRE)
  notes       String?
  isActive    Boolean           @default(true)

  // Types de vélo compatibles. Aucun type associé = composant universel.
  bikeTypes   BikeType[]        @relation("BikeTypeComponents")

  studies     Study[]           @relation("StudyComponents")

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([createdById])
  @@index([category])
}

model AuditLog {
  id       String      @id @default(uuid())
  userId   String
  user     User        @relation(fields: [userId], references: [id])

  action   AuditAction
  entity   String      // "patient", "study", "component"...
  entityId String
  metadata Json?

  timestamp DateTime @default(now())

  @@index([userId])
  @@index([entityId])
  @@index([timestamp])
}
