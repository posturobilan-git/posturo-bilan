// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  PENDING // compte créé, en attente de validation par un ADMIN
  ADMIN
  KINE
}

// Le cycle de vie porte désormais sur l'étude (et non plus le patient) :
// un patient peut avoir plusieurs études, chacune avec son propre statut.
enum StudyStatus {
  study_pending
  study_completed
  report_sent
  followup_pending
  followup_completed
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW_SENSITIVE
  EXPORT
  ANONYMIZE
}

enum ComponentCategory {
  SELLE
  POTENCE
  CINTRE
  CALE_PIEDS
  MANIVELLES
  PEDALES
  AUTRE
}

enum ExerciseCategory {
  SOUPLESSE
  RENFORCEMENT
  MOBILITE
  PROPRIOCEPTION
  AUTRE
}

enum MeasurementCategory {
  SELLE
  CINTRE
  POTENCE
  POSITION
  CALE_PIEDS
  MANIVELLES
  AUTRE
}

// Nature du résultat d'un test physiologique : oui/non, positif/négatif, ou
// valeur numérique (avec unité). Détermine le champ de saisie. POSITIVE_NEGATIVE
// est sémantiquement distinct de YES_NO (signe clinique présent/absent), même si
// tous deux stockés comme booléen. La description du test et une éventuelle note
// libre (commentaire) sont gérées séparément, hors outputType.
enum PhysioOutputType {
  YES_NO
  POSITIVE_NEGATIVE
  VALUE
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  role      Role     @default(PENDING)
  createdBy String?  // id du kiné admin qui a créé ce compte

  patients     Patient[]
  studies      Study[]
  exercises    Exercise[]
  components   BikeComponent[]
  bikeTypes    BikeType[]
  measurements Measurement[]
  riderMeasurements RiderMeasurement[]
  physioTests  PhysioTest[]
  physioTestSections PhysioTestSection[]
  auditLogs    AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

model Patient {
  id              String        @id @default(uuid())
  kineId          String
  kine            User          @relation(fields: [kineId], references: [id])

  // Données de base (récupérées via le webhook de réservation Cal.com)
  email           String        @unique
  firstName       String
  lastName        String
  phone           String?
  bookingId       String?       // identifiant de la réservation Cal.com

  // Données anonymisées (RGPD) — null si anonymisé
  isAnonymized    Boolean       @default(false)

  // Formulaire d'accueil (intake) rempli par le patient via un lien public.
  // Le token est généré à la création ; le patient y accède sur /accueil/[token].
  // Le lien expire à `inviteExpiresAt` (30 j) ou dès que le patient soumet
  // (`inviteCompletedAt` renseigné). On garde le token après soumission pour
  // distinguer « déjà complété » d'un lien invalide.
  inviteToken       String?   @unique
  inviteExpiresAt   DateTime?
  inviteSentAt      DateTime?
  inviteCompletedAt DateTime?

  // Consentement RGPD donné par le patient lors de la soumission du formulaire
  // d'accueil. Conservé au niveau patient car l'accueil alimente toute la suite
  // du parcours. Null si l'accueil a été saisi manuellement par le kiné. La
  // version renvoie au texte des CGU accepté (cf. INTAKE_CGU_VERSION).
  consentAcceptedAt DateTime?
  consentVersion    String?

  intake    PatientIntake?
  studies   Study[]
  followups Followup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kineId])
}

model PatientIntake {
  id        String  @id @default(uuid())
  patientId String  @unique
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Données morphologiques
  heightCm  Float?
  weightKg  Float?

  // Pratique vélo
  bikeType      String?   // route, vtt, gravel, triathlon...
  ridingLevel   String?   // loisir, sportif, compétiteur
  weeklyHours   Float?
  yearsRiding   Int?

  // Douleurs & objectifs
  injuries      String[]  // liste de douleurs déclarées
  goals         String?
  medicalNotes  String?

  // Source des données
  source        String    @default("google_forms") // google_forms | custom_form | manual
  rawData       Json?     // réponses brutes du formulaire

  submittedAt DateTime @default(now())
}

model BikeType {
  id          String   @id @default(uuid())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  name        String   // Route, VTT, Gravel, Triathlon...
  isActive    Boolean  @default(true)

  studies          Study[]
  measurementLinks BikeTypeMeasurement[]
  riderMeasurementLinks BikeTypeRiderMeasurement[]
  physioTestLinks  BikeTypePhysioTest[]
  components        BikeComponent[]       @relation("BikeTypeComponents")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
}

// Une "côte" : mesure relevée pendant une étude. Tronc commun (isCommon) ou
// spécifique à un/plusieurs types de vélo. Gérée par l'admin (CRUD).
model Measurement {
  id          String   @id @default(uuid())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  name        String              // "Hauteur de selle", "Recul de selle"...
  unit        String              // "cm", "mm", "°"
  category    MeasurementCategory @default(AUTRE)
  isCommon    Boolean             @default(false) // tronc commun (tous les vélos)
  isActive    Boolean             @default(true)
  isRequired  Boolean             @default(false) // saisie obligatoire dans l'étude

  // Ordre d'affichage global du tronc commun (côtes communes uniquement).
  // S'applique avant les côtes spécifiques au type de vélo. Ignoré si non commune.
  commonOrder Int                 @default(0)

  // Si non commune, liée à un ou plusieurs types de vélo via la table de
  // configuration (qui porte aussi l'ordre d'affichage propre à chaque vélo).
  bikeTypeLinks BikeTypeMeasurement[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
}

// Configuration d'une étude par type de vélo : quelles côtes (non communes) sont
// relevées pour ce vélo, et dans quel ordre elles s'affichent dans le formulaire.
// Le tronc commun (Measurement.isCommon) s'applique à tous les vélos sans lien
// explicite. L'ordre remplace l'ancien champ global `Measurement.order`.
model BikeTypeMeasurement {
  bikeTypeId    String
  bikeType      BikeType    @relation(fields: [bikeTypeId], references: [id], onDelete: Cascade)
  measurementId String
  measurement   Measurement @relation(fields: [measurementId], references: [id], onDelete: Cascade)

  order Int @default(0) // ordre d'affichage de cette côte pour ce type de vélo

  @@id([bikeTypeId, measurementId])
  @@index([measurementId])
}

// Une mesure du cycliste relevée sur le vélo pendant une étude (KOPS, angle de
// genou, angle de tronc, flexion de coude...). Distincte de `Measurement` (qui
// mesure le vélo seul) : structure de configuration identique (tronc commun ou
// spécifique à des types de vélo, ordre, isRequired), mais l'avant et l'après
// sont saisis sur la même étape du formulaire d'étude. Gérée par l'admin (CRUD).
model RiderMeasurement {
  id          String   @id @default(uuid())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  name        String              // "KOPS", "Angle du genou en bas de pédalage"...
  unit        String              // "mm", "cm", "°"
  category    MeasurementCategory @default(POSITION)
  isCommon    Boolean             @default(false) // tronc commun (tous les vélos)
  isActive    Boolean             @default(true)
  isRequired  Boolean             @default(false) // saisie obligatoire dans l'étude

  // Ordre d'affichage global du tronc commun (mesures communes uniquement).
  commonOrder Int                 @default(0)

  // Si non commune, liée à un ou plusieurs types de vélo via la table de
  // configuration (qui porte aussi l'ordre d'affichage propre à chaque vélo).
  bikeTypeLinks BikeTypeRiderMeasurement[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
}

// Configuration des mesures du cycliste par type de vélo (même rôle que
// BikeTypeMeasurement pour les côtes : sélection + ordre d'affichage).
model BikeTypeRiderMeasurement {
  bikeTypeId         String
  bikeType           BikeType         @relation(fields: [bikeTypeId], references: [id], onDelete: Cascade)
  riderMeasurementId String
  riderMeasurement   RiderMeasurement @relation(fields: [riderMeasurementId], references: [id], onDelete: Cascade)

  order Int @default(0)

  @@id([bikeTypeId, riderMeasurementId])
  @@index([riderMeasurementId])
}

// Un test physiologique relevé pendant une étude. Même logique que Measurement
// (tronc commun ou spécifique à des types de vélo), mais le résultat varie selon
// l'outputType : oui/non, commentaire libre, ou valeur numérique avec unité.
model PhysioTest {
  id          String   @id @default(uuid())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  name        String
  description String?
  outputType  PhysioOutputType @default(VALUE)
  unit        String?           // utilisé pour outputType VALUE (mm, cm, °...)
  isCommon    Boolean          @default(false) // tronc commun (tous les vélos)
  isActive    Boolean          @default(true)
  isRequired  Boolean          @default(false) // saisie obligatoire dans l'étude

  // Ordre d'affichage global du tronc commun (tests communs uniquement).
  commonOrder Int              @default(0)

  // Section/catégorie de regroupement dans le formulaire (Genou, Hanche...).
  // Optionnelle : un test sans section est rangé dans un groupe « Autres ».
  sectionId   String?
  section     PhysioTestSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  bikeTypeLinks BikeTypePhysioTest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([sectionId])
}

// Section de regroupement des tests physio dans le formulaire d'étude
// (ex : Genou, Hanche, Tests dynamiques). Gérée par l'admin (CRUD).
model PhysioTestSection {
  id          String   @id @default(uuid())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  name        String
  order       Int      @default(0) // ordre d'affichage de la section

  physioTests PhysioTest[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
}

// Configuration des tests physio par type de vélo (même rôle que
// BikeTypeMeasurement pour les côtes : sélection + ordre d'affichage).
model BikeTypePhysioTest {
  bikeTypeId   String
  bikeType     BikeType   @relation(fields: [bikeTypeId], references: [id], onDelete: Cascade)
  physioTestId String
  physioTest   PhysioTest @relation(fields: [physioTestId], references: [id], onDelete: Cascade)

  order Int @default(0)

  @@id([bikeTypeId, physioTestId])
  @@index([physioTestId])
}

model Study {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])
  kineId    String
  kine      User    @relation(fields: [kineId], references: [id])

  // Type de vélo étudié (un patient peut avoir plusieurs études / vélos)
  bikeTypeId String
  bikeType   BikeType @relation(fields: [bikeTypeId], references: [id])

  // Statut du cycle de vie de cette étude
  status    StudyStatus @default(study_pending)

  // Valeurs des côtes saisies pour cette étude : avant/après par côte.
  // Tableau de { measurementId, before, after } — voir StudyMeasureValue.
  measureValues Json @default("[]")

  // Valeurs des mesures du cycliste saisies pour cette étude : avant/après par
  // mesure. Tableau de { riderMeasurementId, before, after } — voir
  // StudyRiderMeasureValue. Avant et après sont saisis sur la même étape.
  riderMeasureValues Json @default("[]")

  // Résultats des tests physiologiques : avant/après par test. Tableau de
  // { physioTestId, before, after } où before/after est number|boolean|string|null
  // selon l'outputType du test — voir StudyPhysioResult.
  physioResults Json @default("[]")

  // Ancien format de mesures à champs fixes (legacy, conservé pour les études
  // antérieures à la refacto des côtes dynamiques). Plus alimenté.
  measures  Json?

  // Liens vers bibliothèque
  componentsUsed       BikeComponent[] @relation("StudyComponents")
  exercisesPrescribed  Exercise[]      @relation("StudyExercises")

  // Rapport
  reportUrl   String?   // URL Vercel Blob du PDF
  reportSentAt DateTime?

  // Suivi J+30 : lien public unique vers /suivi/[token]. Le token est généré à
  // l'envoi de l'email de suivi (sendFollowupEmail). On garde le token après
  // soumission (followupCompletedAt renseigné) pour distinguer « déjà complété »
  // d'un lien invalide.
  followupToken       String?   @unique
  followupCompletedAt DateTime?

  observations String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([kineId])
  @@index([bikeTypeId])
  @@index([status])
}

model Followup {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  // Scores
  painLevel     Int?    // 0-10
  comfortScore  Int?    // 0-10
  satisfactionScore Int? // 0-10

  // Pratique
  ridingFrequency String? // "3×/semaine", etc.
  returningToSport Boolean?

  // Texte libre
  generalFeedback String?

  // Source & données brutes
  source    String  @default("google_forms")
  rawResponses Json? // réponses brutes

  submittedAt DateTime @default(now())

  @@index([patientId])
}

model Exercise {
  id          String          @id @default(uuid())
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])

  name        String
  description String
  category    ExerciseCategory @default(AUTRE)
  frequency   String?          // "2×/jour", "3×/semaine"
  duration    String?          // "30 secondes", "3 séries de 10"
  mediaUrl    String?          // lien vidéo ou image explicative
  isActive    Boolean          @default(true)

  studies     Study[]          @relation("StudyExercises")

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([createdById])
}

model BikeComponent {
  id          String            @id @default(uuid())
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id])

  name        String
  brand       String?
  model       String?
  category    ComponentCategory @default(AUTRE)
  notes       String?
  isActive    Boolean           @default(true)

  // Types de vélo compatibles. Aucun type associé = composant universel.
  bikeTypes   BikeType[]        @relation("BikeTypeComponents")

  studies     Study[]           @relation("StudyComponents")

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([createdById])
  @@index([category])
}

model AuditLog {
  id       String      @id @default(uuid())
  userId   String
  user     User        @relation(fields: [userId], references: [id])

  action   AuditAction
  entity   String      // "patient", "study", "component"...
  entityId String
  metadata Json?

  timestamp DateTime @default(now())

  @@index([userId])
  @@index([entityId])
  @@index([timestamp])
}
